// hardening_test.lnl
// Multiline command test for CLI 'run' mode.

CREATE DATABASE hardening_db

USE hardening_db

DATASET test_ds COLUMNS (
    id: INT,
    val: FLOAT,
    meta: STRING
)

INSERT INTO test_ds VALUES (
    1,
    10.5,
    "first_row"
)

INSERT INTO test_ds VALUES (
    2,
    20.5,
    "second_row"
)

SELECT * FROM test_ds WHERE id > 0
