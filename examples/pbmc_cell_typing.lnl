INSERT INTO query_cells VALUES ("cell_0156", "patient_A1", "NK_cell", 755, [0.137, 0.571, 0.453, 0.05, 10.728, 7.753, 0.279, 0.329])
INSERT INTO query_cells VALUES ("cell_0039", "patient_B2", "CD4_T_cell", 948, [9.434, 6.716, 0.826, 0.05, 0.618, 0.527, 0.05, 0.157])
INSERT INTO query_cells VALUES ("cell_0212", "patient_A1", "Dendritic_cell", 1287, [0.576, 0.05, 0.322, 0.235, 0.05, 0.31, 1.451, 7.806])
INSERT INTO query_cells VALUES ("cell_0108", "patient_A1", "B_cell", 1312, [0.236, 0.641, 0.498, 7.699, 0.216, 0.05, 0.058, 0.756])
INSERT INTO query_cells VALUES ("cell_0176", "patient_A1", "CD14_Monocyte", 1228, [0.106, 0.05, 0.396, 0.732, 0.05, 0.05, 9.165, 1.05])

SHOW SCHEMA query_cells

-- ─── 4. Quality control: drop low-complexity cells (standard scRNA-seq QC)
--        via a named, reusable pipeline. ──────────────────────────────────

DEFINE PIPELINE qc_filter AS WHERE n_genes_detected >= 200 THEN ORDER BY cell_id
APPLY PIPELINE qc_filter ON query_cells INTO filtered_cells

SELECT COUNT(*) AS cells_before_qc FROM query_cells
SELECT COUNT(*) AS cells_after_qc FROM filtered_cells

-- ─── 5. Empirical per-type expression profiles ─────────────────────────────
-- AVG_VEC computes the element-wise centroid of each cell type's expression
-- vectors directly from the filtered data — compare against the declared
-- reference_profiles above to sanity-check the simulation matches its
-- intended marker structure.

DATASET observed_profiles FROM filtered_cells SELECT true_cell_type, AVG_VEC(expression) AS observed_profile, COUNT(*) AS n_cells GROUP BY true_cell_type

SHOW observed_profiles
SHOW SCHEMA observed_profiles

-- ─── 6. Reference-based classification (label transfer) ───────────────────
-- For each cell, find its single nearest reference profile by cosine
-- similarity — an index-accelerated similarity JOIN, deduplicated to the
-- top-1 match per cell via a window function over a CTE.

WITH classified AS (SELECT filtered_cells.cell_id AS cell_id, filtered_cells.true_cell_type AS true_cell_type, reference_profiles.cell_type AS predicted_cell_type, COSINE_SIM(filtered_cells.expression, reference_profiles.markers) AS similarity, ROW_NUMBER() OVER (PARTITION BY cell_id ORDER BY similarity DESC) AS rn FROM filtered_cells JOIN reference_profiles ON COSINE_SIM(filtered_cells.expression, reference_profiles.markers) > 0.5) SELECT cell_id, true_cell_type, predicted_cell_type, similarity FROM classified WHERE rn = 1 ORDER BY cell_id LIMIT 15

-- ─── 7. Overall classification accuracy ────────────────────────────────────
-- A real benchmark metric: what fraction of cells did nearest-centroid
-- classification recover correctly against known ground truth? This
-- synthetic panel's marker profiles are deliberately well-separated (each
-- type has 1-2 dominant marker genes), so accuracy here is expected to be
-- very high — that demonstrates the classification logic is correct, not
-- that this particular benchmark was hard. A real reference panel usually
-- shows more overlap between closely related subtypes (see step 8).

WITH classified AS (SELECT filtered_cells.cell_id AS cell_id, filtered_cells.true_cell_type AS true_cell_type, reference_profiles.cell_type AS predicted_cell_type, COSINE_SIM(filtered_cells.expression, reference_profiles.markers) AS similarity, ROW_NUMBER() OVER (PARTITION BY cell_id ORDER BY similarity DESC) AS rn FROM filtered_cells JOIN reference_profiles ON COSINE_SIM(filtered_cells.expression, reference_profiles.markers) > 0.5) SELECT COUNT(*) AS total_classified, SUM(CASE WHEN predicted_cell_type = true_cell_type THEN 1 ELSE 0 END) AS correct_predictions FROM classified WHERE rn = 1

-- ─── 8. Per-type classification accuracy ───────────────────────────────────
-- Which cell types does the classifier confuse? A real diagnostic step —
-- CD4 vs CD8 T cells are given the closest reference profiles here (they
-- share CD3D/CD3E and differ only in CD8A, unlike the other four types,
-- which each have a near-exclusive dominant marker), the same reason
-- they're the hardest pair to separate on a small marker panel in
-- practice. Watch this pair first if per-type accuracy ever dips below
-- 100% on a re-run with different jitter parameters.

WITH classified AS (SELECT filtered_cells.cell_id AS cell_id, filtered_cells.true_cell_type AS true_cell_type, reference_profiles.cell_type AS predicted_cell_type, COSINE_SIM(filtered_cells.expression, reference_profiles.markers) AS similarity, ROW_NUMBER() OVER (PARTITION BY cell_id ORDER BY similarity DESC) AS rn FROM filtered_cells JOIN reference_profiles ON COSINE_SIM(filtered_cells.expression, reference_profiles.markers) > 0.5) SELECT true_cell_type, COUNT(*) AS n_cells, SUM(CASE WHEN predicted_cell_type = true_cell_type THEN 1 ELSE 0 END) AS correct FROM classified WHERE rn = 1 GROUP BY true_cell_type ORDER BY true_cell_type

-- ─── 9. Ranking cells by classification confidence within each type ───────
-- Which cells does the classifier feel most/least sure about? A real QC
-- step for flagging ambiguous cells that might need manual review.

WITH classified AS (SELECT filtered_cells.cell_id AS cell_id, filtered_cells.true_cell_type AS true_cell_type, reference_profiles.cell_type AS predicted_cell_type, COSINE_SIM(filtered_cells.expression, reference_profiles.markers) AS similarity, ROW_NUMBER() OVER (PARTITION BY cell_id ORDER BY similarity DESC) AS rn FROM filtered_cells JOIN reference_profiles ON COSINE_SIM(filtered_cells.expression, reference_profiles.markers) > 0.5) SELECT cell_id, true_cell_type, similarity, RANK() OVER (PARTITION BY true_cell_type ORDER BY similarity DESC) AS confidence_rank FROM classified WHERE rn = 1 ORDER BY true_cell_type, similarity DESC LIMIT 20

-- ─── 10. Cohort summary: JOIN cells with sample/patient metadata ──────────
-- Standard equi-JOIN — sample_metadata (4 rows) against filtered_cells
-- (200+ rows). This is exactly the asymmetric-size case HashJoinExec's
-- smaller-side selection targets: the hash table gets built on the small
-- metadata table regardless of which side of the JOIN it's written on.

SELECT sample_metadata.sample_id AS sample_id, sample_metadata.condition AS condition, sample_metadata.patient_age AS patient_age, COUNT(*) AS n_cells, AVG(filtered_cells.n_genes_detected) AS avg_genes_detected FROM filtered_cells JOIN sample_metadata ON filtered_cells.sample_id = sample_metadata.sample_id GROUP BY sample_id, condition, patient_age ORDER BY sample_id

-- ─── 11. Differential analysis: monocyte activation, healthy vs. sepsis ──
-- Real sepsis immunology reports altered monocyte activation-marker
-- expression during sepsis. This synthetic dataset injects a simplified,
-- documented CD14 boost (1.35x) into sepsis-condition monocytes at
-- generation time (see the data-generation note at the top of this file)
-- so this step has a genuine, recoverable signal to find — not a claim
-- about real measured magnitudes. Compare the empirical monocyte
-- expression centroid between conditions: CD14 (7th of the 8 marker
-- values) should read noticeably higher for sepsis than healthy, while
-- the other 7 marker dimensions stay at noise-level differences.

SELECT sample_metadata.condition AS condition, AVG_VEC(filtered_cells.expression) AS monocyte_profile, COUNT(*) AS n_cells FROM filtered_cells JOIN sample_metadata ON filtered_cells.sample_id = sample_metadata.sample_id WHERE filtered_cells.true_cell_type = "CD14_Monocyte" GROUP BY condition ORDER BY condition

-- ─── 12. Matrix algebra: cell-type similarity structure ────────────────────
-- Stack the 6 reference marker profiles into a matrix and compute its Gram
-- matrix (M x Mᵀ) — the same pairwise-similarity computation underlying
-- hierarchical clustering dendrograms of cell-type relationships.

MATRIX reference_matrix = [[8.0, 7.5, 1.0, 0.3, 0.3, 0.3, 0.2, 0.2], [7.5, 7.0, 4.5, 0.3, 0.4, 1.0, 0.2, 0.2], [0.3, 0.3, 0.2, 9.0, 0.3, 0.2, 0.3, 0.4], [0.4, 0.3, 0.3, 0.2, 8.5, 8.0, 0.3, 0.2], [0.2, 0.2, 0.1, 0.3, 0.2, 0.3, 9.0, 1.2], [0.3, 0.2, 0.2, 0.4, 0.3, 0.3, 1.5, 8.0]]
LET reference_matrix_t = TRANSPOSE reference_matrix
LET celltype_gram_matrix = MATMUL reference_matrix reference_matrix_t
SHOW SHAPE celltype_gram_matrix
SHOW celltype_gram_matrix

-- ─── 13. Persistence: save results for downstream use / reproducibility ──

SAVE DATASET filtered_cells
SAVE DATASET observed_profiles
SHOW DATASET METADATA filtered_cells
LIST DATASET VERSIONS filtered_cells

-- ─── Done ───────────────────────────────────────────────────────────────

USE default
