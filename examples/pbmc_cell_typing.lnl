-- ═══════════════════════════════════════════════════════════════════════
-- Single-Cell PBMC Reference-Based Cell Type Classification
-- ═══════════════════════════════════════════════════════════════════════
-- Replicates a real single-cell RNA-seq analysis technique: reference-based
-- "label transfer" / nearest-centroid classification, as used in tools
-- like Seurat (TransferData) and SingleR to annotate unlabeled cells
-- against a panel of known marker-gene profiles — the same underlying idea
-- as the 10x Genomics "pbmc3k" getting-started tutorial, which classifies
-- peripheral blood cells into T/B/NK/Monocyte/Dendritic subsets using
-- canonical marker genes (CD3D/CD3E/CD8A for T cells, MS4A1 for B cells,
-- GNLY/NKG7 for NK cells, CD14 for monocytes, FCER1A for dendritic cells).
--
-- This script demonstrates nearly the full LINAL feature surface in one
-- coherent scientific workflow: Vector-typed columns, a named pipeline for
-- QC filtering, a vector index + index-accelerated similarity JOIN for
-- classification, window functions (ROW_NUMBER, RANK), CTEs and
-- FROM-subqueries, equi-JOIN against a small metadata table (the exact
-- asymmetric-size case the smaller-side hash join targets), vector
-- aggregates (AVG_VEC) for per-type expression centroids, CASE-based
-- accuracy scoring, matrix algebra (MATMUL/TRANSPOSE) for a cell-type
-- similarity matrix, and dataset persistence.
--
-- Data: synthetic, NOT downloaded. 240 cells were generated with a
-- fixed-seed jitter around 6 canonical PBMC marker-gene profiles (8-gene
-- panel: CD3D, CD3E, CD8A, MS4A1, GNLY, NKG7, CD14, FCER1A). Each cell
-- retains its true simulated cell type as ground truth, so the
-- classifier's accuracy can be measured directly — the way a real method
-- benchmark would validate against a labeled reference, e.g. with tools
-- like splatter/scDesign for simulating single-cell data with known truth.
-- A simplified, explicitly-documented "sepsis raises monocyte CD14" effect
-- is also injected at generation time, purely so step 11's differential
-- analysis has a genuine, recoverable signal to find (see step 11).

DROP DATABASE IF EXISTS pbmc_celltyping
CREATE DATABASE pbmc_celltyping
USE pbmc_celltyping

-- ─── 1. Reference panel: known marker-gene centroids per cell type ────────
-- Vector order: [CD3D, CD3E, CD8A, MS4A1, GNLY, NKG7, CD14, FCER1A]

DATASET reference_profiles COLUMNS (
    cell_type: String,
    source: String,
    markers: Vector(8)
)

INSERT INTO reference_profiles VALUES ("CD4_T_cell", "10x PBMC marker panel", [8.0, 7.5, 1.0, 0.3, 0.3, 0.3, 0.2, 0.2])
INSERT INTO reference_profiles VALUES ("CD8_T_cell", "10x PBMC marker panel", [7.5, 7.0, 4.5, 0.3, 0.4, 1.0, 0.2, 0.2])
INSERT INTO reference_profiles VALUES ("B_cell", "10x PBMC marker panel", [0.3, 0.3, 0.2, 9.0, 0.3, 0.2, 0.3, 0.4])
INSERT INTO reference_profiles VALUES ("NK_cell", "10x PBMC marker panel", [0.4, 0.3, 0.3, 0.2, 8.5, 8.0, 0.3, 0.2])
INSERT INTO reference_profiles VALUES ("CD14_Monocyte", "10x PBMC marker panel", [0.2, 0.2, 0.1, 0.3, 0.2, 0.3, 9.0, 1.2])
INSERT INTO reference_profiles VALUES ("Dendritic_cell", "10x PBMC marker panel", [0.3, 0.2, 0.2, 0.4, 0.3, 0.3, 1.5, 8.0])

CREATE VECTOR INDEX ON reference_profiles(markers)

-- ─── 2. Sample metadata — a small table (4 rows) that will be JOIN'd
--        against the much larger cell table below. This asymmetric size
--        is exactly the case the smaller-side hash join optimizes: the
--        hash table gets built on this table, not the 200+ row one. ──────

DATASET sample_metadata COLUMNS (
    sample_id: String,
    patient_age: Int,
    condition: String,
    collection_site: String
)

INSERT INTO sample_metadata VALUES ("patient_A1", 34, "healthy", "site_north")
INSERT INTO sample_metadata VALUES ("patient_A2", 41, "healthy", "site_north")
INSERT INTO sample_metadata VALUES ("patient_B1", 58, "sepsis", "site_south")
INSERT INTO sample_metadata VALUES ("patient_B2", 63, "sepsis", "site_south")

-- ─── 3. Query cells: unlabeled single-cell expression profiles ────────────
-- true_cell_type is retained as ground truth for validating the classifier
-- below — it is never used as an input signal for classification itself.

DATASET query_cells COLUMNS (
    cell_id: String,
    sample_id: String,
    true_cell_type: String,
    n_genes_detected: Int,
    expression: Vector(8)
)

