-- ─── 6. Nearest-centroid classification (same technique as
--        pbmc_cell_typing.lnl's reference-based cell typing) ───────────────
-- For each held-out real digit image, find its single nearest reference
-- centroid by cosine similarity -- an index-accelerated similarity JOIN,
-- deduplicated to the top-1 match per query via a window function.

WITH classified AS (SELECT query_digits.digit_id AS digit_id, query_digits.true_label AS true_label, reference_centroids.digit_class AS predicted_label, COSINE_SIM(query_digits.pixels, reference_centroids.centroid) AS similarity, ROW_NUMBER() OVER (PARTITION BY digit_id ORDER BY similarity DESC) AS rn FROM query_digits JOIN reference_centroids ON COSINE_SIM(query_digits.pixels, reference_centroids.centroid) > 0.5) SELECT digit_id, true_label, predicted_label, similarity FROM classified WHERE rn = 1 ORDER BY digit_id

-- ─── 7. Overall classification accuracy ────────────────────────────────────
-- Mean-image nearest-centroid classification is a real, well-known
-- (if simple) technique for this dataset. On this real held-out split it
-- scores 25/30 (83.3%) -- meaningfully above chance (10%) but genuinely
-- imperfect, since a single averaged centroid per digit necessarily blurs
-- away real handwriting variation. That imperfection is expected and
-- appropriate for this simple a classifier -- it is not a bug.

WITH classified AS (SELECT query_digits.digit_id AS digit_id, query_digits.true_label AS true_label, reference_centroids.digit_class AS predicted_label, COSINE_SIM(query_digits.pixels, reference_centroids.centroid) AS similarity, ROW_NUMBER() OVER (PARTITION BY digit_id ORDER BY similarity DESC) AS rn FROM query_digits JOIN reference_centroids ON COSINE_SIM(query_digits.pixels, reference_centroids.centroid) > 0.5) SELECT COUNT(*) AS total_classified, SUM(CASE WHEN predicted_label = true_label THEN 1 ELSE 0 END) AS correct_predictions FROM classified WHERE rn = 1

-- ─── 8. Per-class accuracy breakdown ───────────────────────────────────────
-- Which digits does mean-centroid classification confuse? Visually
-- ambiguous pairs (e.g. 3/8, 4/9, 1/7) are the classic failure modes for
-- this technique on this exact dataset.

WITH classified AS (SELECT query_digits.digit_id AS digit_id, query_digits.true_label AS true_label, reference_centroids.digit_class AS predicted_label, COSINE_SIM(query_digits.pixels, reference_centroids.centroid) AS similarity, ROW_NUMBER() OVER (PARTITION BY digit_id ORDER BY similarity DESC) AS rn FROM query_digits JOIN reference_centroids ON COSINE_SIM(query_digits.pixels, reference_centroids.centroid) > 0.5) SELECT true_label, COUNT(*) AS n_queries, SUM(CASE WHEN predicted_label = true_label THEN 1 ELSE 0 END) AS correct FROM classified WHERE rn = 1 GROUP BY true_label ORDER BY true_label

-- ─── 9. Persistence: save results for downstream use / reproducibility ────

SAVE DATASET query_digits
SAVE DATASET reference_centroids
SHOW DATASET METADATA query_digits
LIST DATASET VERSIONS query_digits

-- ─── Done ───────────────────────────────────────────────────────────────

USE default
